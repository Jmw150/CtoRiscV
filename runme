#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 2 ]]; then
    echo "usage: ./runme <input.uC> <output.asm>" >&2
    exit 1
fi

input_file=$1
output_file=$2

if [[ ! -f "$input_file" ]]; then
    echo "input file not found: $input_file" >&2
    exit 1
fi

if [[ ! -d classes ]] || [[ ! -f classes/compiler/Compiler.class ]]; then
    echo "compiler classes not found; running make" >&2
    make >/dev/null
fi

java -cp classes:lib/antlr-4.8-complete.jar compiler.Compiler "$input_file" > "$output_file"
